# Set to "true" to use mock data for development
DEV_MODE=false

# Base URL of the official Foodcourt API deployment
FOODCOURT_API_BASE_URL=http://10.2.154.27:8080/foodcourtapi

# Verification settings for JWTs issued by the Foodcourt JSP backend.
# Use exactly one of EATRIGHT_JWT_SECRET or EATRIGHT_JWT_PUBLIC_KEY.
# The current JSP token has no issuer or audience claims. Leave these unset unless
# the backend starts issuing both claims, then configure their exact values here.
EATRIGHT_JWT_ALGORITHM=HS256
# EATRIGHT_JWT_ISSUER=replace-with-jsp-token-issuer
# EATRIGHT_JWT_AUDIENCE=replace-with-cibus-audience
EATRIGHT_JWT_SECRET=SECRET
# For asymmetric JWTs, remove the secret and select the matching RS/PS/ES/EdDSA algorithm.
# EATRIGHT_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
